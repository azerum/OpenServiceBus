{
  "version": "2.0",
  "logging": {
    "logLevel": {
      "default": "Information",
      "Worker": "Warning",
      "Microsoft.Azure.WebJobs.Hosting": "Warning"
    }
  },
  "extensions": {
    "serviceBus": {
      "maxConcurrentCalls": 4,
      "autoCompleteMessages": true,
      "maxMessageBatchSize": 10,
      "minMessageBatchSize": 1,
      "maxBatchWaitTime": "00:00:02"
    }
  }
}
